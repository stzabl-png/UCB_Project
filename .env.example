# ============================================================
# Optional: External Tool Paths (only for data generation)
# These are NOT needed for training or inference.
# Copy this file to .env and fill in paths for your machine.
# ============================================================

# Hand reconstruction tools
# HAWOR_DIR=/path/to/hawor
# HAPTIC_DIR=/path/to/haptic

# ARCTIC dataset
# ARCTIC_ROOT=/path/to/arctic/unpack

# ContactPose dataset
# CONTACTPOSE_DIR=/path/to/ContactPose

# SAM3D mesh reconstruction
# SAM3D_DIR=/path/to/sam-3d-objects

# Isaac Sim (only for simulation)
# ISAAC_SIM_PATH=/path/to/isaac-sim
